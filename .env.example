DB_URL=
PORT=

# JWT Configuration
JWT_ACCESS_KEY=
JWT_REFRESH_SECRET=
# Access token TTL (vd: 7d, 15m). Mặc định code: 7d
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=365d

# Facebook App Configuration
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Base URLs
BASE_URL=
# Origin FE chính (OAuth redirect / email). Có thể nhiều origin, phân cách bằng dấu phẩy — dùng cho CORS.
# VD: http://localhost:5173,https://newlive-sable.vercel.app
CLIENT_URL=http://localhost:5173,https://newlive-sable.vercel.app
# Tùy chọn: thêm origin CORS khác (cũng phân cách bằng dấu phẩy)
# CLIENT_URLS=

# URL catalog cho AI pipeline (mặc định BASE_URL hoặc http://localhost:8000)
# CRM_CATALOG_API_URL=http://localhost:8000/api/crm-knowledge-catalog
# CRM_CATALOG_CACHE_MS=30000

# Session Secret
SESSION_SECRET=

# Email — gửi link quên mật khẩu (Gmail: dùng App Password, không dùng mật khẩu đăng nhập thường)
EMAIL_NAME=
EMAIL_PASSWORD=
# Tùy chọn branding email
# EMAIL_BRAND_NAME=Bất Động Sản DP
# EMAIL_BRAND_TAGLINE=Nền tảng bất động sản uy tín

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenRouter — một API key cho mọi model (dùng @openrouter/sdk)
OPEN_ROUTER_KEY=
# Hoặc: OPENROUTER_API_KEY=

# Model chat :free — phân cách bằng dấu phẩy; bỏ trống = dùng chuỗi free mặc định
AI_CHAT_MODELS=google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,openai/gpt-oss-20b:free,openai/gpt-oss-120b:free

# Model embedding (có thể tốn credit OpenRouter)
AI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Vector Search (MongoDB Atlas)
VECTOR_SEARCH_INDEX=crm_knowledge_vector_index
VECTOR_SIMILARITY_THRESHOLD=0.6
VECTOR_TEXT_SEARCH_THRESHOLD=0.3

# Tùy chọn: Google AI Studio trực tiếp (không bắt buộc nếu đã có OPEN_ROUTER_KEY)
# GEMINI_API_KEY=
